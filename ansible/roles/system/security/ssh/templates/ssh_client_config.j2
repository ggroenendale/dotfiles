# {{ ansible_managed }}
# SSH client configuration generated by Ansible

# Global defaults
Host *
    # Use ed25519 key first, fallback to older types
    HostKeyAlgorithms ssh-ed25519-cert-v01@openssh.com,ssh-ed25519,ssh-rsa-cert-v01@openssh.com,ssh-rsa
    PubkeyAcceptedKeyTypes ssh-ed25519-cert-v01@openssh.com,ssh-ed25519,ssh-rsa-cert-v01@openssh.com,ssh-rsa

    # Forward agent only to trusted hosts (override per host)
    ForwardAgent no

    # Compression (optional, can speed up slow links)
    Compression yes

    # Keep connection alive
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # Disable X11 forwarding by default (security)
    ForwardX11 no

    # Disable password authentication (use keys)
    PasswordAuthentication no
    ChallengeResponseAuthentication no

    # Use native SSH master connection reuse (speeds up repeated connections)
    ControlMaster auto
    ControlPath ~/.ssh/controlmasters/%r@%h:%p
    ControlPersist 10m

# Create the control master directory if it doesn't exist (handled by the role)
# This path is used by ControlPath above
Exec mkdir -p ~/.ssh/controlmasters

# -----------------------------------------------------------------------------
# Host-specific overrides (customize as needed)
# -----------------------------------------------------------------------------
# Example:
# Host my-server
#     HostName 192.168.1.100
#     User deploy
#     Port 2222
#     IdentityFile ~/.ssh/id_ed25519_my-server
