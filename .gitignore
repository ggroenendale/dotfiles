# Ignore the db_credentials file which contains database secrets
db_credentials.lua

# Ignore environment files
.env

# Ignore the backgrounds folder
backgrounds/

# Ignore Neovim plugin source code and runtime data
.local/share/nvim/

# Ignore the symlink to plugin source code (machine-specific)
nvim-plugins-source

# Ignore scratch/staging directory (temporary files, experiments)
_scratch/

# Ignore lazy lock json file, should be machine specific, if we 
# want to pin plugin versions later we can.
lazy-lock.json

# Ignore ansible vault password
.vault_pass.txt
