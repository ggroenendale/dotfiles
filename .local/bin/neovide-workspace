#!/usr/bin/env bash

# Ensure ~/.local/bin is in PATH for Neovide to find docker symlink
if [[ -d "$HOME/.local/bin" ]] && [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

dir=$( (
    zoxide query -l
    fd -H -t d ".git" ~/projects ~/repos ~/code 2>/dev/null | sed 's|/.git||'
) | sort -u | fuzzel --dmenu --prompt="Workspace")

[ -z "$dir" ] && exit 0

zoxide add "$dir"

neovide "$dir"
